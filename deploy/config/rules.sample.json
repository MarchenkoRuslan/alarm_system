[
  {
    "rule_id": "rule-user-a-trader-position-politics",
    "tenant_id": "tenant-default",
    "name": "User A: position updates, smart score > 80, age > 365, politics",
    "rule_type": "trader_position_update",
    "severity": "warning",
    "expression": {
      "op": "OR",
      "children": [
        {
          "signal": "PositionOpened",
          "op": "eq",
          "threshold": 1,
          "window": {
            "size_seconds": 60,
            "slide_seconds": 10
          }
        },
        {
          "signal": "PositionClosed",
          "op": "eq",
          "threshold": 1,
          "window": {
            "size_seconds": 60,
            "slide_seconds": 10
          }
        },
        {
          "signal": "PositionIncreased",
          "op": "eq",
          "threshold": 1,
          "window": {
            "size_seconds": 60,
            "slide_seconds": 10
          }
        },
        {
          "signal": "PositionDecreased",
          "op": "eq",
          "threshold": 1,
          "window": {
            "size_seconds": 60,
            "slide_seconds": 10
          }
        }
      ]
    },
    "cooldown_seconds": 60,
    "filters": {
      "category_tags": [
        "politics"
      ],
      "min_smart_score": 80,
      "min_account_age_days": 365
    },
    "version": 1
  },
  {
    "rule_id": "rule-user-b-volume-iran",
    "tenant_id": "tenant-default",
    "name": "User B: 5m volume spikes on Iran markets",
    "rule_type": "volume_spike_5m",
    "severity": "warning",
    "expression": {
      "signal": "volume_5m",
      "op": "gte",
      "threshold": 100000,
      "window": {
        "size_seconds": 300,
        "slide_seconds": 30
      }
    },
    "cooldown_seconds": 180,
    "filters": {
      "category_tags": [
        "iran"
      ],
      "iran_tag_only": true
    },
    "version": 1
  },
  {
    "rule_id": "rule-user-c-new-market-liquidity",
    "tenant_id": "tenant-default",
    "name": "User C: new markets with liquidity > 100k in politics/esports/crypto",
    "rule_type": "new_market_liquidity",
    "severity": "warning",
    "expression": {
      "signal": "liquidity_usd",
      "op": "gte",
      "threshold": 100000,
      "window": {
        "size_seconds": 60,
        "slide_seconds": 10
      }
    },
    "cooldown_seconds": 300,
    "filters": {
      "category_tags": [
        "politics",
        "esports",
        "crypto"
      ]
    },
    "deferred_watch": {
      "enabled": true,
      "target_liquidity_usd": 100000,
      "ttl_hours": 336
    },
    "version": 1
  }
]
