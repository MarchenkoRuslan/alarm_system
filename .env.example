# Required runtime variables.
ALARM_ASSET_IDS=asset_id_1,asset_id_2
ALARM_GAMMA_TAG_IDS=
ALARM_TELEGRAM_BOT_TOKEN=replace_with_real_token

# Runtime mode and thresholds.
ALARM_EXECUTE_SENDS=true
ALARM_DEDUP_BUCKET_SECONDS=60
ALARM_DEDUP_SAFETY_MARGIN_SECONDS=5
ALARM_DISPATCH_MAX_ATTEMPTS=3
ALARM_DELIVERY_IDEMPOTENCY_TTL_SECONDS=86400

# Backpressure controls.
ALARM_BACKPRESSURE_CAPACITY=10000
ALARM_BACKPRESSURE_WARNING_UTILIZATION=0.70
ALARM_BACKPRESSURE_CRITICAL_UTILIZATION=0.90
ALARM_BACKPRESSURE_RECOVERY_SAMPLES=3

# Logging cadence.
ALARM_PROGRESS_EVERY_EVENTS=500
ALARM_METRICS_EVERY_SECONDS=30
