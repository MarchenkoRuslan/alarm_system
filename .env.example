# Required runtime variables.
ALARM_ASSET_IDS=asset_id_1,asset_id_2
ALARM_GAMMA_TAG_IDS=
# Worker only: periodic Gamma metadata poll (0 = bootstrap-only at startup).
# If > 0, ALARM_GAMMA_TAG_IDS must be non-empty.
ALARM_GAMMA_POLL_INTERVAL_SECONDS=0
ALARM_GAMMA_POLL_BACKOFF_MAX_SECONDS=300
ALARM_GAMMA_POLL_JITTER_RATIO=0.1
ALARM_TELEGRAM_BOT_TOKEN=replace_with_real_token

# Interactive/API storage settings.
ALARM_ENV=dev
ALARM_USE_DATABASE_CONFIG=false
ALARM_POSTGRES_DSN=postgresql://alarm_user:alarm_password@localhost:5432/alarm_system
ALARM_CONFIG_CACHE_TTL_SECONDS=30
ALARM_AUTO_APPLY_SQL_MIGRATIONS=true

# Postgres container defaults (docker-compose).
ALARM_POSTGRES_DB=alarm_system
ALARM_POSTGRES_USER=alarm_user
ALARM_POSTGRES_PASSWORD=alarm_password

# API runtime settings.
ALARM_API_HOST=0.0.0.0
ALARM_API_PORT=8000

# Runtime mode and thresholds.
ALARM_EXECUTE_SENDS=true
ALARM_DEDUP_BUCKET_SECONDS=60
ALARM_DEDUP_SAFETY_MARGIN_SECONDS=5
ALARM_DISPATCH_MAX_ATTEMPTS=3
ALARM_DELIVERY_IDEMPOTENCY_TTL_SECONDS=86400

# Backpressure controls.
ALARM_BACKPRESSURE_CAPACITY=10000
ALARM_BACKPRESSURE_WARNING_UTILIZATION=0.70
ALARM_BACKPRESSURE_CRITICAL_UTILIZATION=0.90
ALARM_BACKPRESSURE_RECOVERY_SAMPLES=3

# Logging cadence.
ALARM_PROGRESS_EVERY_EVENTS=500
ALARM_METRICS_EVERY_SECONDS=30
