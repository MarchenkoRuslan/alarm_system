{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alarm-system.local/schemas/canonical_event.v1.schema.json",
  "title": "CanonicalEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "source",
    "event_type",
    "market_ref",
    "event_ts",
    "ingested_ts",
    "payload",
    "payload_hash",
    "trace"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 8
    },
    "source": {
      "type": "string",
      "enum": ["polymarket", "kalshi", "polymarket_onchain"]
    },
    "source_event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "market_snapshot",
        "orderbook_delta",
        "trade",
        "ticker",
        "market_lifecycle",
        "wallet_activity",
        "metadata_refresh"
      ]
    },
    "market_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["market_id"],
      "properties": {
        "market_id": { "type": "string" },
        "event_id": { "type": "string" },
        "outcome_id": { "type": "string" }
      }
    },
    "entity_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wallet_address": { "type": "string" },
        "entity_id": { "type": "string" },
        "label": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "event_ts": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "payload_hash": {
      "type": "string",
      "minLength": 16
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correlation_id", "partition_key"],
      "properties": {
        "correlation_id": { "type": "string" },
        "partition_key": { "type": "string" },
        "producer": { "type": "string" },
        "adapter_version": { "type": "string" }
      }
    }
  }
}
